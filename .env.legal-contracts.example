# Legal Contracts Environment Configuration
# Copy to .env.local and fill in your values

# =======================
# REQUIRED
# =======================

# Signature verification secret
SIGNATURE_SECRET=your_secure_random_secret_key_here_min_32_chars

# =======================
# OPTIONAL - DocuSign Integration
# =======================

# Get these from https://developers.docusign.com
DOCUSIGN_CLIENT_ID=your_docusign_client_id
DOCUSIGN_CLIENT_SECRET=your_docusign_client_secret
DOCUSIGN_REDIRECT_URI=https://yourapp.com/api/contracts/docusign/callback

# =======================
# OPTIONAL - Encryption Keys
# =======================

# For encrypting sensitive contracts (AES-256-GCM)
CONTRACT_ENCRYPTION_KEY=your_32_byte_hex_key_here
CONTRACT_ENCRYPTION_ALGORITHM=AES-256-GCM

# =======================
# OPTIONAL - Audit Trail Storage
# =======================

# Store screenshots in S3 or other service
SCREENSHOT_STORAGE_TYPE=local|s3|gcs
SCREENSHOT_S3_BUCKET=your-bucket
SCREENSHOT_S3_REGION=us-east-1
SCREENSHOT_S3_ACCESS_KEY=xxx
SCREENSHOT_S3_SECRET_KEY=xxx

# =======================
# OPTIONAL - Geolocation Service
# =======================

# Get location for signing users
IPSTACK_API_KEY=your_ipstack_key

# =======================
# OPTIONAL - Email Notifications
# =======================

# Send contract reminders
SENDGRID_API_KEY=your_sendgrid_key
CONTRACT_NOTIFICATION_FROM=legal@yourapp.com

# =======================
# OPTIONAL - Legal Archive
# =======================

# Long-term evidence storage
LEGAL_ARCHIVE_BUCKET=your-archive-bucket
LEGAL_ARCHIVE_RETENTION_YEARS=7

# =======================
# OPTIONAL - Blockchain (Future)
# =======================

# Store contract hashes on blockchain
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_NETWORK=ethereum|pi-network
BLOCKCHAIN_CONTRACT_ADDRESS=0x...
