{
  "$schema": "https://json.schemastore.org/pi-app-manifest.json",
  "name": "Triumph Synergy - Quantum Financial System",
  "short_name": "Triumph QFS",
  "description": "The Most Advanced Quantum Financial System (QFS) Platform powered by Pi Network. Features Pi SDK 2.0 integration, 90% Pi payments, Fast-Track KYC/KYB, Multi-Sig business wallets, quantum-resistant security, NESARA/GESARA compliance, and immortal infrastructure. Pi Network is our primary payment backbone.",
  "version": "2.0.0",
  "pi_sdk_version": "2.0",
  
  "display": "standalone",
  "orientation": "portrait-primary",
  "scope": "/",
  "start_url": "/",
  "theme_color": "#8B5CF6",
  "background_color": "#0F0F23",
  "dir": "ltr",
  "lang": "en",

  "developer": {
    "name": "Jeremiah Drains",
    "organization": "Triumph Synergy LLC",
    "email": "contact@triumph-synergy.com",
    "website": "https://triumph-synergy.com",
    "pi_username": "@triumph_synergy"
  },

  "app": {
    "id": "triumph-synergy",
    "category": "finance",
    "subcategory": "payments",
    "rating": "E",
    "languages": ["en", "es", "fr", "de", "zh", "ja", "ko", "pt", "ru", "ar"],
    "countries": "all",
    "tags": ["qfs", "quantum", "payments", "kyc", "multi-sig", "stellar", "enterprise"]
  },

  "pi_network_focus": {
    "primary_payment_method": true,
    "payment_percentage": 90,
    "pi_backbone": true,
    "pios_licensed": true,
    "fast_track_kyc": true,
    "fast_track_kyb": true,
    "multi_sig_wallets": true
  },

  "pi_browser": {
    "optimized": true,
    "native_experience": true,
    "offline_support": true,
    "push_notifications": true,
    "deep_linking": true,
    "share_target": true,
    "features": [
      "payments",
      "authentication",
      "wallet",
      "kyc_verification",
      "multi_sig"
    ]
  },

  "platform": {
    "pi_network": {
      "enabled": true,
      "mainnet": true,
      "testnet": true,
      "primary": true,
      "pi_browser_first": true
    },
    "stellar": {
      "enabled": true,
      "network": "public",
      "horizon_url": "https://horizon.stellar.org"
    },
    "web": {
      "enabled": true,
      "pwa": true,
      "service_worker": true
    },
    "mobile": {
      "enabled": true,
      "pi_browser": true,
      "responsive": true
    }
  },

  "permissions": ["payments", "username", "wallet_address", "user_info"],

  "payment_config": {
    "enabled": true,
    "endpoints": {
      "approve": "/api/pi/approve",
      "complete": "/api/pi/complete",
      "cancel": "/api/pi/cancel",
      "value": "/api/pi/value",
      "status": "/api/pi/status"
    },
    "limits": {
      "min_amount": 10.0,
      "max_amount": 100000.0,
      "daily_limit": 500000.0
    },
    "currencies": {
      "primary": "PI",
      "secondary": ["USD", "EUR"]
    },
    "settlement": {
      "method": "stellar",
      "automatic": true,
      "batch_interval": 3600
    },
    "internal_pi": {
      "enabled": true,
      "multiplier": 1.5
    },
    "external_pi": {
      "enabled": true,
      "multiplier": 1.0
    }
  },

  "auth_config": {
    "oauth": {
      "enabled": true,
      "callback_url": "/api/auth/pi/callback",
      "logout_url": "/logout"
    },
    "biometric": {
      "enabled": true,
      "webauthn": true,
      "passkeys": true
    }
  },

  "webhooks": {
    "payment": "/api/webhooks/pi/payment",
    "user": "/api/webhooks/pi/user",
    "app": "/api/webhooks/pi/app"
  },

  "urls": {
    "production": "https://triumph-synergy.vercel.app",
    "production_testnet": "https://triumph-synergy-testnet.vercel.app",
    "development_mainnet": "https://triumphsynergy0576.pinet.com",
    "development_testnet": "https://triumphsynergy1991.pinet.com",
    "staging": "https://triumph-synergy-staging.vercel.app",
    "development": "http://localhost:3000",
    "documentation": "https://github.com/jdrains110-beep/triumph-synergy/tree/main/docs",
    "support": "https://github.com/jdrains110-beep/triumph-synergy/issues",
    "privacy_policy": "/legal/privacy",
    "terms_of_service": "/legal/terms"
  },

  "features": {
    "payments": {
      "pi_payments": true,
      "stellar_settlement": true,
      "smart_contracts": true,
      "escrow": true,
      "recurring": true,
      "multi_sig": true
    },
    "security": {
      "biometric_auth": true,
      "two_factor": true,
      "encryption": true,
      "audit_logging": true,
      "quantum_resistant": true,
      "zero_trust": true
    },
    "compliance": {
      "fast_track_kyc": true,
      "fast_track_kyb": true,
      "aml_screening": true,
      "sanctions_screening": true,
      "pep_screening": true,
      "gdpr_compliant": true,
      "mica_regulation": true
    },
    "wallets": {
      "individual_wallets": true,
      "business_wallets": true,
      "multi_sig_wallets": true,
      "auto_provisioning": true,
      "spending_limits": true,
      "transaction_rules": true
    },
    "integrations": {
      "streaming_royalties": true,
      "gaming_platforms": true,
      "health_platforms": true,
      "entertainment_hub": true,
      "pirc_protocol": true
    },
    "quantum_systems": {
      "quantum_fortress": true,
      "central_node_supreme": true,
      "immortal_infrastructure": true,
      "threat_detection_ai": true
    }
  },

  "integrations": {
    "github": {
      "repo": "jdrains110-beep/triumph-synergy",
      "branch": "main",
      "ci_cd": true
    },
    "vercel": {
      "project": "triumph-synergy",
      "team": "jeremiah-drains-projects",
      "auto_deploy": true
    },
    "stellar": {
      "network": "mainnet",
      "horizon": "https://horizon.stellar.org"
    },
    "supabase": {
      "enabled": true,
      "database": true,
      "auth": true
    }
  },

  "deployment": {
    "provider": "vercel",
    "regions": ["iad1"],
    "edge_functions": true,
    "serverless_functions": {
      "max_duration": 30,
      "memory": 1024
    }
  },

  "assets": {
    "logo": "/logo.png",
    "icon": "/icon.png",
    "banner": "/banner.png",
    "screenshots": [
      "/screenshots/payment.png",
      "/screenshots/dashboard.png",
      "/screenshots/wallet.png"
    ]
  },

  "metadata": {
    "created": "2025-01-01T00:00:00Z",
    "updated": "2026-01-13T00:00:00Z",
    "schema_version": "1.0"
  }
}
