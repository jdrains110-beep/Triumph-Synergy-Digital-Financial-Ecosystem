{
  "name": "ai-chatbot",
  "version": "^4.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "tsx scripts/run-migrations-if-present.ts && next build",
    "start": "next start",
    "start-server-for-tests": "pnpm exec next dev",
    "lint": "npx ultracite@5.3.9 check",
    "format": "npx ultracite@5.3.9 fix",
    "db:generate": "npx drizzle-kit@latest generate",
    "db:migrate": "npx tsx lib/db/migrate.ts",
    "db:studio": "npx drizzle-kit@latest studio",
    "db:push": "npx drizzle-kit@latest push",
    "db:pull": "npx drizzle-kit@latest pull",
    "db:check": "npx drizzle-kit@latest check",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "test": "cross-env RUN_MIGRATIONS=true PLAYWRIGHT=True tsx scripts/run-migrations-if-present.ts && cross-env PLAYWRIGHT=True pnpm exec playwright test"
  },
  "dependencies": {
