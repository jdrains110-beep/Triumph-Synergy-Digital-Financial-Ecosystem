<!DOCTYPE html>
<html>
<head>
  <title>Triumph-Synergy - Pi Network Payment</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
      color: #fff;
      min-height: 100vh;
      padding: 20px;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    header {
      text-align: center;
      margin-bottom: 60px;
      padding: 40px 0;
    }
    
    header h1 {
      font-size: 3em;
      background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 10px;
    }
    
    header p {
      font-size: 1.2em;
      color: #a0aec0;
    }
    
    .content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      margin-bottom: 40px;
    }
    
    @media (max-width: 768px) {
      .content {
        grid-template-columns: 1fr;
      }
      
      header h1 {
        font-size: 2em;
      }
    }
    
    .card {
      background: rgba(30, 27, 75, 0.5);
      border: 1px solid rgba(59, 130, 246, 0.2);
      border-radius: 12px;
      padding: 30px;
      backdrop-filter: blur(10px);
    }
    
    .card h2 {
      font-size: 1.5em;
      margin-bottom: 20px;
      color: #60a5fa;
    }
    
    .card p {
      line-height: 1.8;
      color: #cbd5e1;
      margin-bottom: 15px;
    }
    
    .pi-button {
      background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
      color: white;
      border: none;
      padding: 15px 40px;
      font-size: 1.1em;
      font-weight: bold;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      width: 100%;
      margin-top: 20px;
    }
    
    .pi-button:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
    }
    
    .pi-button:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    
    .status {
      margin-top: 20px;
      padding: 15px;
      background: rgba(59, 130, 246, 0.1);
      border-left: 4px solid #3b82f6;
      border-radius: 4px;
      display: none;
    }
    
    .status.show {
      display: block;
    }
    
    .status.success {
      background: rgba(34, 197, 94, 0.1);
      border-left-color: #22c55e;
    }
    
    .status.error {
      background: rgba(239, 68, 68, 0.1);
      border-left-color: #ef4444;
    }
    
    .transaction-id {
      font-family: monospace;
      background: rgba(0, 0, 0, 0.3);
      padding: 10px;
      border-radius: 4px;
      margin: 10px 0;
      word-break: break-all;
    }
    
    footer {
      text-align: center;
      color: #64748b;
      padding: 40px 0;
      border-top: 1px solid rgba(59, 130, 246, 0.1);
      margin-top: 60px;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>💳 Triumph-Synergy Entertainment Hub</h1>
      <p>Pi Network Payment Integration</p>
    </header>
    
    <div class="content">
      <!-- Pi Payment Card -->
      <div class="card">
        <h2>🥧 Pi Network Payment</h2>
        <p>Purchase entertainment services using Pi Network cryptocurrency.</p>
        <p><strong>Amount:</strong> <%= @payment_amount %> Pi</p>
        <p>This integration uses the official Pi Network SDK for secure payment processing.</p>
        
        <button id="buyButton" class="pi-button" data-pi-sdk-target="buybutton">
          💳 Buy with Pi Network
        </button>
        
        <div id="paymentStatus" class="status">
          <div id="statusMessage"></div>
          <div id="transactionDisplay"></div>
        </div>
      </div>
      
      <!-- Entertainment Hub Info -->
      <div class="card">
        <h2>🎬 Entertainment Hub</h2>
        <p><strong>Features:</strong></p>
        <ul style="margin-left: 20px;">
          <li>Artist Payment System</li>
          <li>Fair Compensation Algorithm</li>
          <li>Multi-Million Transaction Support</li>
          <li>Real-Time Settlement</li>
          <li>Revenue Allocation</li>
        </ul>
        
        <h3 style="margin-top: 20px; margin-bottom: 10px;">Integration Status</h3>
        <p>✅ Pi Network SDK Ready<br>
           ✅ Payment API Active<br>
           ✅ Production Environment<br>
           ✅ Secure Connection</p>
      </div>
    </div>
    
    <footer>
      <p>© 2026 Triumph-Synergy Entertainment Hub. Pi Network Integration v1.0</p>
    </footer>
  </div>
  
  <!-- Pi Network SDK -->
  <script src="https://sdk.minepi.com/pi-sdk.js"></script>
  <script>
    // Initialize Pi SDK
    if (window.Pi) {
      window.Pi.init({ version: "2.0", appId: "<%= @pi_app_id %>" });
    }
    
    // Handle buy button click
    document.getElementById("buyButton").addEventListener("click", async function() {
      try {
        this.disabled = true;
        this.textContent = "Processing...";
        
        // Call backend API
        const response = await fetch("/api/v1/payments", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            payment: {
              amount: <%= @payment_amount %>,
              product_id: "entertainment-pro",
              user_id: "user_" + Date.now()
            }
          })
        });
        
        const data = await response.json();
        
        if (data.success) {
          showStatus("success", "Payment initiated! Transaction: " + data.transaction_id);
        } else {
          showStatus("error", "Payment failed: " + data.error);
          this.disabled = false;
          this.textContent = "💳 Buy with Pi Network";
        }
      } catch (error) {
        showStatus("error", "Error: " + error.message);
        this.disabled = false;
        this.textContent = "💳 Buy with Pi Network";
      }
    });
    
    function showStatus(type, message) {
      const statusEl = document.getElementById("paymentStatus");
      const messageEl = document.getElementById("statusMessage");
      
      statusEl.className = "status show " + type;
      messageEl.textContent = message;
      
      // Extract transaction ID
      const match = message.match(/Transaction: (pi_txn_\w+)/);
      if (match) {
        const transactionEl = document.getElementById("transactionDisplay");
        transactionEl.innerHTML = '<div style="margin-top: 10px;"><strong>Transaction ID:</strong><div class="transaction-id">' + match[1] + '</div></div>';
      }
    }
  </script>
</body>
</html>
