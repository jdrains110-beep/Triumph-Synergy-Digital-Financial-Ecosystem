{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "env": {
    "POSTGRES_URL": "postgres://user:pass@localhost:5432/triumph_dummy",
    "REDIS_URL": "redis://localhost:6379",
    "AUTH_SECRET": "dev-auth-secret",
    "PI_API_KEY": "dev-pi-api-key",
    "PI_INTERNAL_API_KEY": "dev-pi-internal-key",
    "GITHUB_WEBHOOK_SECRET": "dev-github-webhook-secret",
    "STELLAR_HORIZON_URL": "https://horizon-testnet.stellar.org",
    "INTERNAL_PI_MULTIPLIER": "1.5",
    "INTERNAL_PI_MIN_VALUE": "10.0",
    "EXTERNAL_PI_MIN_VALUE": "1.0"
  },
  "headers": [
    {
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ],
      "source": "/validation-key.txt"
    }
  ],
  "outputDirectory": ".next",
  "devCommand": "pnpm dev",
  "public": [
    "/validation-key.txt",
    "/api/validation-key"
  ]
}
