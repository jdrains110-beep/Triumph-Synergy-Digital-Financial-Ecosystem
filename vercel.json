{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "regions": ["iad1"],
  "alias": [
    "triumph-synergy.vercel.app",
    "triumph-synergy-testnet.vercel.app"
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/.well-known/pi-app-verification",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/api/pi-verification",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ],
  "devCommand": "pnpm dev",
  "functions": {
    "app/api/pi/**/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "app/api/stellar/**/*.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "pages/api/pi/**/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://triumph-synergy.vercel.app/:path*",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": ".*-jeremiah-drains-projects.vercel.app"
        }
      ]
    },
    {
      "source": "/:path*",
      "destination": "https://triumph-synergy.vercel.app/:path*",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": ".*-git-.*-jeremiah-drains-projects.vercel.app"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/pi-app-verification",
      "destination": "/api/pi-verification"
    },
    {
      "source": "/.well-known/pi-app-verification.json",
      "destination": "/api/pi-verification"
    }
  ],
  "env": {
    "NEXT_PUBLIC_PI_APP_ID": "triumph-synergy",
    "NEXT_PUBLIC_PI_BROWSER_DETECTION": "true",
    "NEXT_PUBLIC_PI_SDK_URL": "https://sdk.minepi.com/pi-sdk.js",
    "AUTH_SECRET": "triumph-synergy-pi-app-studio-auth-secret-2026-production",
    "NEXTAUTH_SECRET": "triumph-synergy-pi-app-studio-auth-secret-2026-production",
    "DEPLOYMENT_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/stellar-settlement",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/payment-reconciliation",
      "schedule": "0 0 * * *"
    }
  ]
}

