{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "env": {
    "POSTGRES_URL": "postgres://user:pass@localhost:5432/triumph_dummy",
    "REDIS_URL": "redis://localhost:6379",
    "AUTH_SECRET": "dev-auth-secret-minimum-32-chars-long-for-build",
    "NEXTAUTH_SECRET": "dev-nextauth-secret-minimum-32-chars-for-build",
    "PI_API_KEY": "dev-pi-api-key",
    "PI_INTERNAL_API_KEY": "dev-pi-internal-key",
    "GITHUB_WEBHOOK_SECRET": "dev-github-webhook-secret",
    "STELLAR_HORIZON_URL": "https://horizon-testnet.stellar.org",
    "SUPABASE_URL": "https://dummy.supabase.co",
    "SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkdW1teSIsInJvbGUiOiJhbm9uIn0.dummy",
    "SUPABASE_SERVICE_ROLE_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkdW1teSIsInJvbGUiOiJzZXJ2aWNlX3JvbGUifQ.dummy",
    "INTERNAL_PI_MULTIPLIER": "1.5",
    "INTERNAL_PI_MIN_VALUE": "10.0",
    "EXTERNAL_PI_MIN_VALUE": "1.0"
