# Triumph Synergy Environment Variables Configuration
# This file documents all required and optional environment variables
# Copy to .env.local for local development and fill in your values

# ============================================================================
# CRITICAL DEPENDENCIES (Required for system to start)
# ============================================================================

# PostgreSQL Database Connection (CRITICAL)
# Format: postgresql://username:password@host:port/database
# Generate password: openssl rand -base64 16
POSTGRES_URL=postgresql://postgres:password@localhost:5432/triumph_synergy

# Redis Cache Connection (CRITICAL)  
# Format: redis://[:password]@host:port[/database]
REDIS_URL=redis://localhost:6379

# ============================================================================
# AUTHENTICATION
# ============================================================================

# NextAuth.js Configuration
# Generate secrets: openssl rand -base64 32
AUTH_SECRET=generate-random-secret-min-32-characters
NEXTAUTH_SECRET=generate-random-secret-min-32-characters
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# PAYMENT SYSTEMS (Pi Network - Primary, Apple Pay - Secondary)
# ============================================================================

# ⚠️  CRITICAL: Pi Network API Credentials
# These MUST be set in Vercel Environment Variables dashboard ONLY
# NEVER commit these to git or .env.local
# See: VERCEL_ENV_SETUP_GUIDE.md for detailed instructions

# Pi Network API Key (Server-side, NEVER expose client-side)
# Mainnet: Obtain from Pi App Studio dashboard
# Testnet: Obtain from Pi App Studio dashboard (testnet app)
PI_API_KEY=your-pi-network-api-key-here

# Pi App ID (Can be public - identifies your app)
# Mainnet App ID: e485546ac793cb7
# Testnet App ID: 60f6dc6830c60061
PI_APP_ID=your-pi-app-id-here

# Pi SDK Configuration (CRITICAL for Pi Browser)
# Public - safe to expose
NEXT_PUBLIC_PI_APP_ID=triumph-synergy
NEXT_PUBLIC_PI_SANDBOX=false
PI_SANDBOX_MODE=false

# ============================================================================
# Pi Domain Configuration (Environment-specific)
# ============================================================================

# MAINNET (Production):
# NEXT_PUBLIC_APP_URL=https://triumphsynergy7386.pinet.com
# NEXTAUTH_URL=https://triumphsynergy7386.pinet.com
# PI_NETWORK_MAINNET_VALIDATION_KEY=efee2c5a2ce4e5079efeb7eb88e9460f8928f87e900d1fb2075b3f6279fb5b612550875c1fb8b0f1b749b96028e66c833bfc6e52011997a4c38d3252e7b2b195

# TESTNET (Staging):
# NEXT_PUBLIC_APP_URL=https://triumphsynergy1991.pinet.com
# NEXTAUTH_URL=https://triumphsynergy1991.pinet.com
# PI_NETWORK_TESTNET_VALIDATION_KEY=75b333f8b28771b24f2fb6adb87b225cc1b58eef8bd5a747d388a98dca1084e331eebc385c6a63885a887f4a0382bc883adeeeccdce9240b4cb8c10faaed93a3

# For local development, copy this section and uncomment one:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Payment Routing Configuration
INTERNAL_PI_MULTIPLIER=1.5
INTERNAL_PI_MIN_VALUE=10.0
EXTERNAL_PI_MIN_VALUE=1.0

# ============================================================================
# BLOCKCHAIN (Stellar Network for Settlement)
# ============================================================================

STELLAR_HORIZON_URL=https://horizon.stellar.org

# ============================================================================
# RPC BRIDGE CONFIGURATION (Blockchain & External Bridge)
# ============================================================================
# Pi Network RPC Endpoints (via RPC Bridge)
NEXT_PUBLIC_PI_RPC_MAINNET=https://rpc.minepi.com
NEXT_PUBLIC_PI_RPC_TESTNET=https://rpc.testnet.minepi.com
NEXT_PUBLIC_PI_RPC_TIMEOUT=30000
NEXT_PUBLIC_PI_RPC_RETRIES=3

# Horizon Data Layer (External data/structure access)
NEXT_PUBLIC_HORIZON_ENDPOINT=https://horizon.com/api/v1
HORIZON_API_KEY=your-horizon-api-key

# External API Bridge (Connection to outside world)
NEXT_PUBLIC_EXTERNAL_API_ENDPOINT=https://api.triumph-synergy.pi

# ============================================================================
# SUPABASE (Optional Database Alternative)
# ============================================================================

SUPABASE_URL=https://triumph-synergy.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================================
# COMPLIANCE FRAMEWORKS
# ============================================================================

# MICA Regulation (Markets in Crypto-Assets)
MICA_ENABLED=true
MICA_JURISDICTION=EU

# KYC/AML Configuration
KYC_ENABLED=true
AML_SCREENING_LEVEL=strict

# GDPR Data Protection
GDPR_ENABLED=true
GDPR_DATA_RETENTION_DAYS=365

# ============================================================================
# INTEGRATIONS
# ============================================================================

# GitHub Webhooks
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Vercel AI Gateway (Optional)
AI_GATEWAY_API_KEY=your-ai-gateway-key

# Vercel Blob Storage (Optional)
BLOB_READ_WRITE_TOKEN=your-blob-storage-token

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

NODE_ENV=development
# NEXT_PUBLIC_DEBUG=true
# NEXT_PUBLIC_LOG_LEVEL=debug

# ============================================================================
# VERCEL-SPECIFIC (Auto-set by Vercel Platform)
# ============================================================================
# These are automatically set when deployed to Vercel:
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-vercel-deployment-url
