# Pi Stable Revoluter Core - Environment Configuration
# 
# Copy this file to .env.local and fill in the values

# =============================================================================
# PI NETWORK MAINNET
# =============================================================================

# Pi Network Mainnet RPC URL
PI_MAINNET_RPC_URL=https://rpc.pi.network

# Deployed contract addresses on Pi Mainnet
PI_MAINNET_STABLECOIN_ADDRESS=
PI_MAINNET_RESERVE_MANAGER_ADDRESS=
PI_MAINNET_GOVERNANCE_ADDRESS=

# =============================================================================
# PI NETWORK TESTNET
# =============================================================================

# Pi Network Testnet RPC URL
PI_TESTNET_RPC_URL=https://testnet-rpc.pi.network

# Deployed contract addresses on Pi Testnet
PI_TESTNET_STABLECOIN_ADDRESS=
PI_TESTNET_RESERVE_MANAGER_ADDRESS=
PI_TESTNET_GOVERNANCE_ADDRESS=

# =============================================================================
# ETHEREUM MAINNET
# =============================================================================

# Ethereum Mainnet RPC URL (Infura, Alchemy, etc.)
ETHEREUM_MAINNET_RPC_URL=

# Deployed contract addresses on Ethereum Mainnet
ETHEREUM_MAINNET_STABLECOIN_ADDRESS=
ETHEREUM_MAINNET_RESERVE_MANAGER_ADDRESS=
ETHEREUM_MAINNET_GOVERNANCE_ADDRESS=

# =============================================================================
# ETHEREUM SEPOLIA TESTNET
# =============================================================================

# Ethereum Sepolia Testnet RPC URL
ETHEREUM_SEPOLIA_RPC_URL=

# Deployed contract addresses on Ethereum Sepolia
ETHEREUM_SEPOLIA_STABLECOIN_ADDRESS=
ETHEREUM_SEPOLIA_RESERVE_MANAGER_ADDRESS=
ETHEREUM_SEPOLIA_GOVERNANCE_ADDRESS=

# =============================================================================
# RESERVE ASSETS
# =============================================================================

# Pi Token Address
PI_TOKEN_ADDRESS=

# USDC Address (for reserve backing)
USDC_ADDRESS=

# =============================================================================
# SECURITY
# =============================================================================

# Emergency Contact Address
EMERGENCY_CONTACT_ADDRESS=

# Multi-sig Signers (comma-separated addresses)
MULTISIG_SIGNERS=

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================

# Metrics Endpoint
METRICS_ENDPOINT=

# Alert Webhook URL (Slack, Discord, etc.)
ALERT_WEBHOOK_URL=

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Pi Stable API Base URL
PI_STABLE_API_URL=https://api.triumphsynergy.com/pi-stable
